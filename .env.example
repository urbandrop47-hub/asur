# ── Shared ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Backend (Railway) ────────────────────────────────────────────────────────
PORT=4000
MONGODB_URI=
SUPER_ADMIN_BOOTSTRAP_ENABLED=false
SUPER_ADMIN_BOOTSTRAP_EMAIL=
SUPER_ADMIN_BOOTSTRAP_FIREBASE_UID=
SUPER_ADMIN_BOOTSTRAP_NAME=
SUPER_ADMIN_BOOTSTRAP_PHONE=
SUPER_ADMIN_BOOTSTRAP_AVATAR_URL=
JWT_SECRET=
ADMIN_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
RAZORPAY_KEY=
RAZORPAY_SECRET=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ACCOUNT_ID=
R2_PUBLIC_URL=
RESEND_API_KEY=
ADMIN_EMAIL=
# AI features — Claude Haiku (visual search, size rec, description gen)
# Leave blank to disable AI features gracefully (returns 503)
ANTHROPIC_API_KEY=

# ── Frontend web (Vercel — asur-web) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app
NEXT_PUBLIC_SITE_URL=https://weareasur.in
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_RAZORPAY_KEY=
# Also set R2_PUBLIC_URL here — used by next.config.mjs at BUILD TIME to
# add the R2 hostname to Next.js image remote patterns.
R2_PUBLIC_URL=
NEXT_PUBLIC_ADMIN_URL=https://asur-admin-delta.vercel.app
# Sentry (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Frontend admin (Vercel — asur-admin) ─────────────────────────────────────
# NEXT_PUBLIC_API_URL — same Railway URL as web
# NEXT_PUBLIC_FIREBASE_* — same values as web (same Firebase project)
# R2_PUBLIC_URL — same value as web (admin shows product images)

# ── Frontend vendor (Vercel — asur-vendor) ───────────────────────────────────
# NEXT_PUBLIC_API_URL — same Railway URL as web
# NEXT_PUBLIC_FIREBASE_* — same values as web (same Firebase project)
# R2_PUBLIC_URL — same value as web (vendor shows order item thumbnails)
